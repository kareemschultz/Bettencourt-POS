{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bettencourt-POS",
  "version": "0.1.0",
  "identifier": "com.karetech.bettencourt-pos",
  "build": {
    "frontendDist": "../build/client",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Bettencourt-POS",
        "width": 1366,
        "height": 768,
        "maximized": true,
        "titleBarStyle": "visible",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
