{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs",
		"test": "bun test ./src/__tests__/*.test.ts"
	},
	"dependencies": {
		"@Bettencourt-POS/api": "workspace:*",
		"@Bettencourt-POS/auth": "workspace:*",
		"@Bettencourt-POS/db": "workspace:*",
		"@Bettencourt-POS/env": "workspace:*",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.1",
		"hono": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@Bettencourt-POS/config": "workspace:*",
		"@types/bun": "catalog:",
		"tsdown": "^0.16.5",
		"typescript": "^5"
	}
}
