# Bettencourt POS — Production Environment Variables
# Copy this file and fill in real values. Never commit the real .env file.

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/bettencourt_pos

# Better Auth secret — must be at least 32 random characters
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
