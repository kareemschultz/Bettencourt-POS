{
	"name": "Bettencourt-POS",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"hono": "^4.8.2",
			"@orpc/server": "^1.12.2",
			"@orpc/openapi": "^1.12.2",
			"@orpc/zod": "^1.12.2",
			"better-auth": "1.5.2",
			"@orpc/client": "^1.12.2"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @Bettencourt-POS/db db:push",
		"db:studio": "turbo -F @Bettencourt-POS/db db:studio",
		"db:generate": "turbo -F @Bettencourt-POS/db db:generate",
		"db:migrate": "turbo -F @Bettencourt-POS/db db:migrate",
		"db:start": "turbo -F @Bettencourt-POS/db db:start",
		"db:watch": "turbo -F @Bettencourt-POS/db db:watch",
		"db:stop": "turbo -F @Bettencourt-POS/db db:stop",
		"db:down": "turbo -F @Bettencourt-POS/db db:down",
		"db:seed": "turbo -F @Bettencourt-POS/db db:seed",
		"check": "biome check --write .",
		"prepare": "husky",
		"test": "turbo test"
	},
	"dependencies": {
		"@Bettencourt-POS/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@Bettencourt-POS/config": "workspace:*",
		"@biomejs/biome": "^2.2.0",
		"@types/bun": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"turbo": "^2.8.12",
		"typescript": "^5"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"packageManager": "bun@1.3.10"
}
